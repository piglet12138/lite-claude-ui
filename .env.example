PORT=3040

# Anthropic API (or any compatible endpoint)
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_API_KEY=sk-ant-xxxxx
MODEL=claude-opus-4-7

# Extra API keys for parallel tasks (comma-separated, optional)
# Used for long document generation sub-agents. Keys auto-rotate with cooldown on failure.
SUB_AGENT_KEYS=

# Admin account (required — used to seed the first user on startup)
ACCESS_EMAIL=admin@example.com
ACCESS_PASSWORD=change-me
SESSION_SECRET=replace_with_a_long_random_string

# Web search (optional, 5-engine fallback: Serper > Tavily > Google CSE > Brave > DuckDuckGo)
ENABLE_WEB_SEARCH=false
BRAVE_SEARCH_API_KEY=
SERPER_API_KEY=
TAVILY_API_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=
WEB_SEARCH_RESULT_COUNT=3

# Email notifications for bug reports (optional, via Resend)
RESEND_API_KEY=
NOTIFY_EMAILS=admin@example.com

# Google Docs upload (optional)
# Create an OAuth 2.0 Client ID of type "Web application" in Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:3040/api/google/callback
GOOGLE_TOKEN_FILE=.google-token.json
