PORT=3040

# OpenAI-compatible chat completions endpoint.
LUCKY_BASE_URL=https://luckyapi.chat/v1
LUCKY_API_KEY=replace_with_your_api_key
MODEL=claude-opus-4-7

# Minimal single-user login.
ACCESS_EMAIL=admin@example.com
ACCESS_PASSWORD=change-me
SESSION_SECRET=replace_with_a_long_random_string

# Optional Brave Search integration.
ENABLE_WEB_SEARCH=false
BRAVE_SEARCH_API_KEY=
WEB_SEARCH_RESULT_COUNT=3

# Optional Google Docs upload integration.
# Create an OAuth 2.0 Client ID of type "Web application" in Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:3040/api/google/callback
GOOGLE_TOKEN_FILE=.google-token.json
